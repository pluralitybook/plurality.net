{
  "name": "plurality.net",
  "version": "1.0.0",
  "private": true,
  "license": "CC0-1.0",
  "type": "module",
  "scripts": {
    "dev": "bunx --bun astro dev",
    "build": "bunx --bun astro build && bunx --bun pagefind --site dist",
    "preview": "bunx --bun astro preview",
    "check": "bunx --bun astro sync && tsc --noEmit",
    "clean": "rm -rf dist",
    "test": "vp test",
    "test:unit": "vp test tests/unit",
    "test:regression": "vp test tests/regression",
    "test:coverage": "vp test --coverage",
    "test:e2e": "bunx --bun playwright test",
    "test:e2e:install": "bunx --bun playwright install --with-deps",
    "lint:html": "html-validate \"dist/index.html\" \"dist/404.html\" \"dist/read/index.html\" \"dist/about/index.html\" \"dist/endorsements/index.html\" \"dist/zh/index.html\" \"dist/ja/index.html\" \"dist/de/index.html\" \"dist/th/index.html\" \"dist/el/index.html\"",
    "vectorize:sync-book": "bun scripts/vectorize-sync-book.mjs",
    "lint": "vp fmt --check . && vp lint",
    "format": "vp fmt .",
    "prepare": "vp config",
    "ci": "bun --bun run clean && bun --bun run check && bun --bun run lint && bun --bun run test && bun --bun run build && bun --bun run lint:html"
  },
  "dependencies": {
    "astro": "^7.0.6",
    "markdown-it": "^14.1.1",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-footnote": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@playwright/test": "^1.59.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "4.1.10",
    "html-validate": "^10.13.1",
    "pagefind": "1.5.0-beta.1",
    "serve": "^14.2.6",
    "typescript": "^7.0.2",
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4",
    "vite-plus": "0.2.4"
  },
  "overrides": {
    "vite": "npm:@voidzero-dev/vite-plus-core@0.2.4"
  },
  "devEngines": {
    "packageManager": {
      "name": "bun",
      "version": "1.3.14",
      "onFail": "download"
    }
  }
}
